INPUT_PARAMETERS
#Parameters (1.General)
suffix                  H
calculation             scf
symmetry                -1
pseudo_dir              ../../H_orb
orbital_dir             ../../H_orb
basis_type              lcao
ecutwfc                 100
#Parameters (2. SCF iterations)
scf_nmax                100
scf_thr                 1e-9
#Parameters (3. Solve KS equation)
nspin                   1
nbands                  8
ks_solver               genelpa
#Parameters (4.Smearing)
smearing_method         gauss
smearing_sigma          0.01
#Parameters (5.Mixing)
mixing_type             broyden
mixing_beta             0.8
mixing_gg0              0
dft_functional  hse
#Parameters (6.Deepks)
#deepks_out_labels   1
deepks_scf	        1
deepks_model	    model4.ptg

#deepks_bandgap      1

#bessel_descriptor_lmax         2 #lmax used in generating spherical bessel functions
#bessel_descriptor_ecut         50.000000 #energy cutoff for spherical bessel functions(Ry)